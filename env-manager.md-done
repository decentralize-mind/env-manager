# 🔄 8. Key Rotation Engine (ZERO DOWNTIME)

👉 `rotator.rs`

```rust
use tokio::time::{sleep, Duration};

pub async fn rotation_loop() {
    loop {
        println!("🔄 Rotating secrets...");

        // 1. Request new secret from Vault
        // 2. Update runtime cache
        // 3. Keep old + new temporarily

        sleep(Duration::from_secs(3600)).await; // every 1h
    }
}
```

---

# 🧠 9. Runtime Secret Injection

👉 `main.rs`

```rust
mod config;
mod secrets;

use config::{loader::load_config, validator::validate};
use secrets::vault::VaultClient;

#[tokio::main]
async fn main() {
    let mut cfg = load_config().expect("Config failed");
    validate(&cfg);

    let vault = VaultClient::new(
        "http://127.0.0.1:8200".into(),
        std::env::var("VAULT_TOKEN").unwrap(),
    );

    // 🔐 Replace env secrets with Vault secrets
    let jwt = vault.get_secret("secret/data/app", "jwt").await;

    cfg.security.jwt_secret = jwt;

    println!("✅ Secure config loaded");
}
```

